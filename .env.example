# ── TigerGraph Savanna (graph + vector DB) ──────────────────────────────────
TIGERGRAPH_HOST=your-instance.i.tgcloud.io
TIGERGRAPH_GRAPH=GraphRAGDemo
TIGERGRAPH_USERNAME=your-username
TIGERGRAPH_PASSWORD=your-password
TIGERGRAPH_SECRET=your-secret
TIGERGRAPH_PORT=443
TIGERGRAPH_USE_SSL=true

# ── Gemini (generation + judge) ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key
GOOGLE_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# ── Shared generation config (same for all 3 pipelines) ──────────────────────
MAX_OUTPUT_TOKENS=1000
